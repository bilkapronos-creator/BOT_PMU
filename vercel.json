{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "buildCommand": "node scripts/generate-config.js",
  "outputDirectory": ".",
  "installCommand": "",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/config.js", "dest": "/config.js" },
    { "src": "/auth.js", "dest": "/auth.js" },
    { "src": "/admin.html", "dest": "/admin.html" },
    { "src": "/admin.js", "dest": "/admin.js" },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/sw.js", "dest": "/sw.js" },
    { "src": "/icons/(.*)", "dest": "/icons/$1" },
    { "src": "/vendor/(.*)", "dest": "/vendor/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
