# Copiez ce fichier en .env à la racine (jamais committer .env)

# football-data.org — en-tête X-Auth-Token (plan gratuit)
FOOTBALL_DATA_API_KEY=

# Proxy France pour scraper Winamax (CI / local hors FR)
# VELORA_PROXY_URL=http://user:pass@host:port
# Auth auto si user:pass dans l'URL (défaut) ; interactif seulement sans identifiants :
# VELORA_PROXY_INTERACTIVE=1
# VELORA_PROXY_USER=login
# VELORA_PROXY_PASS=motdepasse
